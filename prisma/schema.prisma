generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  CLIENT_ADMIN
  CLIENT_USER
}

model Client {
  id       String  @id @default(cuid())
  name     String
  slug     String  @unique
  logoUrl  String?
  color    String?
  isActive Boolean @default(true)

  users      User[]
  forecast   ForecastGasto[]
  historico  HistoricoData[]
  comisiones ComisionMensual[]
  uploads    DataUpload[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           String  @id @default(cuid())
  clientId     String
  name         String
  email        String  @unique
  passwordHash String
  role         Role
  isActive     Boolean @default(true)

  client  Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  uploads DataUpload[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
}

// Aggregated from Budget/Forecast Excel sheets by dirección + área + mes
model ForecastGasto {
  id         String @id @default(cuid())
  clientId   String
  anio       Int
  mes        Int
  direccion  String
  area       String
  budget     Float  @default(0)
  forecast   Float  @default(0)
  hcBudget   Int    @default(0)
  hcForecast Int    @default(0)

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId, anio, mes])
  @@index([clientId, direccion])
  @@index([clientId, area])
}

// From Historico Excel sheet — one row per población per month
model HistoricoData {
  id            String @id @default(cuid())
  clientId      String
  anio          Int
  mes           Int
  poblacion     String
  hcPresupuesto Int    @default(0)
  hcReal        Int    @default(0)
  forecast      Float  @default(0)
  real          Float  @default(0)
  budget        Float  @default(0)
  altas         Int    @default(0)
  bajas         Int    @default(0)

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, anio, mes, poblacion])
  @@index([clientId, anio])
}

// From Comisiones Excel sheet — transposed to one row per month
model ComisionMensual {
  id            String @id @default(cuid())
  clientId      String
  anio          Int
  mes           Int
  hcProyectado  Int    @default(0)
  presupuestado Float  @default(0)
  realHc        Int    @default(0)
  realCosto     Float  @default(0)

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, anio, mes])
  @@index([clientId])
}

model DataUpload {
  id       String @id @default(cuid())
  clientId String
  userId   String
  anio     Int
  fileName String
  sheets   Int    @default(0)

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([clientId, anio])
}
